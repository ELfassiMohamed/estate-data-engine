    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT\n  (SELECT COUNT(*) FROM listings)                                        AS total_rows,\n  (SELECT COUNT(*) FROM listings WHERE source = 'avito')                 AS avito_count,\n  (SELECT COUNT(*) FROM listings WHERE source = 'mubawab')               AS mubawab_count,\n  (SELECT COUNT(*) FROM listings WHERE url_status = 'dead')              AS dead_urls,\n  (SELECT COUNT(*) FROM listings WHERE url_status = 'alive')             AS alive_urls,\n  (SELECT COUNT(*) FROM listings WHERE url_status IS NULL)               AS unchecked_urls,\n  (SELECT COUNT(*) FROM listings WHERE price IS NULL)                    AS missing_price,\n  (SELECT COUNT(*) FROM listings WHERE surface IS NULL)                  AS missing_surface,\n  (SELECT COUNT(*) FROM listings WHERE city IS NULL OR city = '')        AS missing_city,\n  (SELECT COUNT(*) FROM listings WHERE title IS NULL OR title = '')      AS missing_title;",
        "options": {}
      },
