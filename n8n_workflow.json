    {
      "parameters": {
        "operation": "executeQuery",
        "query": "DELETE FROM listings\nWHERE id NOT IN (\n  SELECT MIN(id)\n  FROM listings\n  GROUP BY LOWER(TRIM(url))\n);\nSELECT COUNT(*) AS duplicates_deleted FROM (\n  SELECT LOWER(TRIM(url))\n  FROM listings\n  GROUP BY LOWER(TRIM(url))\n  HAVING COUNT(*) > 1\n) t;",
        "options": {}
      },
      "id": "192f2b0d-b4cf-4c5c-9ea3-c53adfcc57a2",
      "name": "Delete Exact URL Duplicates",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.4,
      "position": [
        160,
        -176
      ],
      "credentials": {
        "postgres": {
          "id": "vMYRJN9V6sCDdmAj",
          "name": "Postgres account"
        }
      }
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "UPDATE listings SET\n  title       = NULLIF(TRIM(REGEXP_REPLACE(title, '\\s+', ' ', 'g')), ''),\n  city        = NULLIF(TRIM(REGEXP_REPLACE(city, '\\s+', ' ', 'g')), ''),\n  type_bien   = NULLIF(TRIM(REGEXP_REPLACE(type_bien, '\\s+', ' ', 'g')), ''),\n  description = NULLIF(TRIM(REGEXP_REPLACE(description, '\\s+', ' ', 'g')), ''),\n  url         = TRIM(LOWER(url))\nWHERE\n  title       IS DISTINCT FROM NULLIF(TRIM(REGEXP_REPLACE(title, '\\s+', ' ', 'g')), '')\n  OR city     IS DISTINCT FROM NULLIF(TRIM(REGEXP_REPLACE(city, '\\s+', ' ', 'g')), '')\n  OR type_bien IS DISTINCT FROM NULLIF(TRIM(REGEXP_REPLACE(type_bien, '\\s+', ' ', 'g')), '')\n  OR description IS DISTINCT FROM NULLIF(TRIM(REGEXP_REPLACE(description, '\\s+', ' ', 'g')), '')\n  OR url      IS DISTINCT FROM TRIM(LOWER(url));\nSELECT COUNT(*) AS normalized_rows FROM listings;",
        "options": {}
      },
      "id": "ef1a2a85-ed32-48f6-9155-b0b5b2173233",
      "name": "Normalize Fields",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.4,
      "position": [
        160,
        16
      ],
      "credentials": {
        "postgres": {
          "id": "vMYRJN9V6sCDdmAj",
          "name": "Postgres account"
        }
      }
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT id, url FROM listings\nWHERE url IS NOT NULL AND url != ''\nORDER BY scraped_at DESC\nLIMIT 100;",
        "options": {}
      },
